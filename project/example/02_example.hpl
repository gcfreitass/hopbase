  <transform>
    <name>orders_table</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>north</connection>
    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
