      <fontsize>13</fontsize>
      <height>58</height>
      <xloc>736</xloc>
      <yloc>176</yloc>
      <note>Lookup: used to enrich the current stream by adding new fields in the pipeline.
In contrast of the most Join Transforms, Lookup transforms don't change 
the number of the rows of the data stream. </note>
      <width>485</width>
    </notepad>
  </notepads>
  <order>
    <hop>
      <from>orders_table</from>
      <to>orders_sort_rows</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>orders_sort_rows</from>
      <to>merge_join</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>order_details_table</from>
      <to>order_details_sort_row</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>order_details_sort_row</from>
      <to>merge_join</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>orders_table 2</from>
      <to>productid_lookup</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>merge_join</name>
    <type>MergeJoin</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <join_type>INNER</join_type>
    <keys_1>
      <key>order_id</key>
    </keys_1>
    <keys_2>
      <key>order_id</key>
    </keys_2>
    <transform1>orders_sort_rows</transform1>
    <transform2>order_details_sort_row</transform2>
    <attributes/>
    <GUI>
      <xloc>464</xloc>
      <yloc>368</yloc>
    </GUI>
  </transform>
  <transform>
    <name>order_details_sort_row</name>
    <type>SortRows</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compress>N</compress>
    <directory>${java.io.tmpdir}</directory>
    <fields>
      <field>
        <ascending>Y</ascending>
        <case_sensitive>N</case_sensitive>
        <collator_enabled>N</collator_enabled>
        <collator_strength>0</collator_strength>
        <name>order_id</name>
        <presorted>N</presorted>
      </field>
    </fields>
    <sort_prefix>out</sort_prefix>
    <sort_size>1000000</sort_size>
    <unique_rows>N</unique_rows>
    <attributes/>
    <GUI>
      <xloc>272</xloc>
      <yloc>432</yloc>
    </GUI>
  </transform>
  <transform>
    <name>order_details_table</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>north</connection>
    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>SELECT
  order_id
, product_id
, unit_price
, quantity
, discount
FROM "public".order_details
</sql>
    <variables_active>N</variables_active>
    <attributes/>
    <GUI>
      <xloc>96</xloc>
      <yloc>432</yloc>
    </GUI>
  </transform>
  <transform>
    <name>orders_sort_rows</name>
    <type>SortRows</type>
    <description/>
