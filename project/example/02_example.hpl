  <transform>
    <name>productid_lookup</name>
    <type>DBLookup</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <cache>N</cache>
    <cache_load_all>N</cache_load_all>
    <cache_size>0</cache_size>
    <connection>north</connection>
    <lookup>
      <eat_row_on_failure>N</eat_row_on_failure>
      <fail_on_multiple>N</fail_on_multiple>
      <key>
        <condition>=</condition>
        <field>order_id</field>
        <name>order_id</name>
      </key>
      <schema>"public"</schema>
      <table>order_details</table>
      <value>
        <name>product_id</name>
        <trim_type>none</trim_type>
        <type>String</type>
      </value>
    </lookup>
    <attributes/>
